{
  "name": "dc26-base",
  "scripts": {
    "dev": "npm-run-all --parallel watch:main build:js",
    "watch:main": "chokidar \"css/**/*.css\" \"blocks/**/*.css\" -c \"npx postcss ./css/style.css -o ./build/style.css\"",
    "build:main": "npx postcss ./css/style.css -o ./build/style.css",
    "build:js": "esbuild ./scripts/dc26-front.js --bundle --minify --outfile=./build/app.js --watch",
    "build": "npm-run-all build:main build:js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "baseline-browser-mapping": "^2.9.19",
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.27.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^14.0.0",
    "postcss-nested": "^5.0.3",
    "postcss-nested-ancestors": "^3.0.0"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "swiper": "^11.1.1"
  }
}
